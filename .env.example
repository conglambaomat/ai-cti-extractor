# =====================================================================
# AI-Assisted CTI Extractor — Environment Variables Template
# Copy to .env and fill in your actual values. NEVER commit .env.
# =====================================================================

# ----- Application -----
APP_ENV=development                 # development | staging | production
APP_NAME=cti-extractor
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-32-bytes-hex   # used for signing tokens, audit chain

# ----- Authentication (API access for analysts) -----
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ----- PostgreSQL (authoritative relational store) -----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cti_extractor
POSTGRES_USER=cti
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://cti:change-me@localhost:5432/cti_extractor

# ----- Elasticsearch (lexical search + reviewer triage) -----
ELASTIC_URL=http://localhost:9200
ELASTIC_USER=
ELASTIC_PASSWORD=
ELASTIC_INDEX_REPORTS=cti_reports
ELASTIC_INDEX_OBJECTS=cti_objects
ELASTIC_INDEX_TRIAGE=cti_triage

# ----- ChromaDB (vector retrieval) -----
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_TENANT=cti
CHROMA_COLLECTION_REPORT_CHUNKS=report_chunks
CHROMA_COLLECTION_ATTACK=attack_techniques
CHROMA_COLLECTION_STIX=stix_docs
CHROMA_COLLECTION_VALIDATED=validated_examples

# ----- Object storage (raw reports, OCR, attachments) -----
S3_ENDPOINT=http://localhost:9000   # MinIO local
S3_BUCKET=cti-reports
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# ----- LLM provider (RAG-grounded judge / re-ranker) -----
# Choose ONE primary; secondaries are optional fallbacks.
LLM_PROVIDER=openai                 # openai | anthropic | azure | local
LLM_MODEL=gpt-4o-mini               # or claude-3-5-sonnet, etc.
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Local model gateway (Ollama / vLLM / LM Studio)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3.1:8b-instruct

# ----- Embedding model -----
EMBED_PROVIDER=local                # local | openai
EMBED_MODEL=BAAI/bge-base-en-v1.5
EMBED_DIM=768

# ----- Domain encoders (NER / RE / TTP candidates) -----
NER_MODEL_PATH=models/securebert-cti-ner
RE_MODEL_PATH=models/securebert-cti-re
TTP_CANDIDATE_MODEL_PATH=models/secroberta-attack
ATTACK_RERANKER_THRESHOLD=0.55

# ----- MITRE ATT&CK data source -----
ATTACK_STIX_BUNDLE_URL=https://raw.githubusercontent.com/mitre/cti/master/enterprise-attack/enterprise-attack.json
ATTACK_REFRESH_DAYS=14

# ----- STIX / TAXII export targets -----
TAXII_SERVER_URL=
TAXII_USERNAME=
TAXII_PASSWORD=
TAXII_COLLECTION_ID=

# ----- OpenCTI integration -----
OPENCTI_URL=http://localhost:4000
OPENCTI_TOKEN=

# ----- MISP integration -----
MISP_URL=
MISP_API_KEY=
MISP_VERIFY_TLS=true

# ----- OCR (only when page is image-only) -----
TESSERACT_CMD=tesseract
OCR_LANGUAGES=eng+vie

# ----- Translation cache (for non-English reports) -----
TRANSLATION_PROVIDER=local          # local | google | azure
GOOGLE_TRANSLATE_API_KEY=

# ----- Job queue (background extraction pipeline) -----
REDIS_URL=redis://localhost:6379/0
WORKER_CONCURRENCY=2

# ----- Observability -----
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=

# ----- Security policy -----
ALLOW_EXTERNAL_LLM=false            # if false, all LLM calls go local-only
REDACT_BEFORE_LLM=true              # strip emails/IPs/internal IDs before external call
ENABLE_AUDIT_LOG=true               # immutable audit trail of every extraction/edit/export

# ----- Feature flags -----
FEATURE_OCR=true
FEATURE_TRANSLATION=true
FEATURE_LLM_JUDGE=true
FEATURE_HUMAN_REVIEW=true
FEATURE_TAXII_EXPORT=false
FEATURE_OPENCTI_EXPORT=false
FEATURE_MISP_EXPORT=false
